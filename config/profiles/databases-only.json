{
  "profileName": "databases-only",
  "description": "Database-focused profile. Azure SQL and Cosmos DB with supporting networking, security, and monitoring. Good for database benchmark testing.",
  "version": "2.0.0",
  "modules": {
    "monitoring": {
      "enabled": true,
      "features": { "alertRules": false, "alertEmail": "" }
    },
    "networking": {
      "enabled": true,
      "features": { "bastionSku": "None", "enableAppGateway": false, "enableFirewall": "None", "enableVpnGateway": false, "enableDdos": false, "enableNatGateway": false, "enablePrivateDnsZones": false }
    },
    "security": {
      "enabled": true,
      "features": { "keyVault": true, "managedIdentity": true, "defenderForCloud": false, "sentinel": false, "allowedCidrRanges": [] }
    },
    "compute": { "enabled": false },
    "storage": { "enabled": false },
    "databases": {
      "enabled": true,
      "features": { "sqlDatabase": true, "sqlVm": false, "cosmosDb": true, "postgresql": false, "mysql": false, "redis": false }
    },
    "appservices": { "enabled": false },
    "containers": { "enabled": false },
    "integration": { "enabled": false },
    "ai": { "enabled": false },
    "data": { "enabled": false },
    "governance": {
      "enabled": true,
      "features": { "automationAccount": false, "budget": true, "budgetAmount": 100, "resourceLocks": false, "policyAssignments": false,
        "budgetAlertEmail": "" }
    }
  },
  "seedDummyData": true
}
