{
  "profileName": "minimal",
  "description": "Minimal Azure demo environment. Monitoring, networking, security, and one Windows VM. Low cost, good for initial orientation.",
  "version": "2.0.0",
  "modules": {
    "monitoring": {
      "enabled": true,
      "features": { "logAnalyticsWorkspace": true, "applicationInsights": false, "actionGroup": true, "alertRules": false }
    },
    "networking": {
      "enabled": true,
      "features": { "bastionSku": "Developer", "enableAppGateway": false, "enableFirewall": "None", "enableVpnGateway": false, "enableDdos": false, "enableNatGateway": false, "enablePrivateDnsZones": false }
    },
    "security": {
      "enabled": true,
      "features": { "keyVault": true, "managedIdentity": true, "defenderForCloud": false, "sentinel": false }
    },
    "compute": {
      "enabled": true,
      "features": { "windowsVm": true, "linuxVm": false, "vmss": false, "enableAutoShutdown": true, "vmSku": "Standard_B2s", "domainController": false, "domainName": "" }
    },
    "storage": {
      "enabled": true,
      "features": { "generalPurposeStorage": true, "dataLakeGen2": false, "fileShares": false, "enableSoftDelete": false, "enableVersioning": false }
    },
    "databases": { "enabled": false },
    "appservices": { "enabled": false },
    "containers": { "enabled": false },
    "integration": { "enabled": false },
    "ai": { "enabled": false },
    "data": { "enabled": false },
    "governance": {
      "enabled": true,
      "features": { "automationAccount": true, "budget": true, "budgetAmount": 50, "resourceLocks": false, "policyAssignments": false }
    }
  },
  "seedDummyData": false
}
