{
  "profileName": "compute-only",
  "description": "Compute-focused profile. Windows + Linux VMs with supporting networking, security, and monitoring. Good for VM benchmark testing.",
  "version": "2.0.0",
  "modules": {
    "monitoring": {
      "enabled": true,
      "features": { "logAnalyticsWorkspace": true, "applicationInsights": false, "actionGroup": true, "alertRules": false }
    },
    "networking": {
      "enabled": true,
      "features": { "bastionSku": "Developer", "enableAppGateway": false, "enableFirewall": "None", "enableVpnGateway": false, "enableDdos": false, "enableNatGateway": false, "enablePrivateDnsZones": false }
    },
    "security": {
      "enabled": true,
      "features": { "keyVault": true, "managedIdentity": true, "defenderForCloud": false, "sentinel": false }
    },
    "compute": {
      "enabled": true,
      "features": { "windowsVm": true, "linuxVm": true, "vmss": true, "enableAutoShutdown": false, "vmSku": "Standard_B2s", "domainController": false, "domainName": "" }
    },
    "storage": { "enabled": false },
    "databases": { "enabled": false },
    "appservices": { "enabled": false },
    "containers": { "enabled": false },
    "integration": { "enabled": false },
    "ai": { "enabled": false },
    "data": { "enabled": false },
    "governance": {
      "enabled": true,
      "features": { "automationAccount": true, "budget": true, "budgetAmount": 150, "resourceLocks": false, "policyAssignments": false }
    }
  },
  "seedDummyData": false
}
