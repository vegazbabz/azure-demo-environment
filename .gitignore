# ── PDFs (e.g. CIS Benchmark — redistribute separately) ──────────────────────
*.pdf

# ── Test output ───────────────────────────────────────────────────────────────
tests/results/

# ── Local environment / secrets ───────────────────────────────────────────────
.env
.env.*
*.local.json
local.*.json

# ── Certificates and keys ─────────────────────────────────────────────────────
*.pfx
*.pem
*.key
*.p12
*.cer

# ── Azure CLI token cache ─────────────────────────────────────────────────────
.azure/

# ── PowerShell temp / log files ───────────────────────────────────────────────
*.log
*.tmp

# ── VS Code Local History extension ──────────────────────────────────────────
.history/

# ── Bicep compiled outputs (az bicep build) ───────────────────────────────────
*.compiled.json

# ── Azure deployment output / parameter snapshots ────────────────────────────
*.deploymentOutput.json
azuredeploy.json
azuredeploy.parameters.json

# ── Copilot prompt files (internal — not for public distribution) ─────────────
.github/prompts/

