<Project Sdk="Microsoft.NET.Sdk">
  <!--
    This project is NOT built or published.
    It exists solely so Dependabot can track the NuGet packages that
    scripts/seed-data.ps1 downloads on-demand, and open automated PRs
    when security advisories are published.

    When Dependabot opens a PR bumping a version here, you MUST also update
    scripts/seed-data.ps1:
      1. Change the -Version argument in the Get-AdeNuGetDll call
      2. Update -ExpectedSha512 with the new packageHash from:
         https://api.nuget.org/v3/registration5-gz-semver2/<id>/<version>.json
  -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsPublishable>false</IsPublishable>
  </PropertyGroup>
  <ItemGroup>
    <!-- Keep versions in sync with scripts/seed-data.ps1 -->
    <PackageReference Include="Npgsql" Version="8.0.3" />
    <PackageReference Include="MySqlConnector" Version="2.3.7" />
  </ItemGroup>
</Project>
